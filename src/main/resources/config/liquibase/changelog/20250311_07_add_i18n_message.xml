<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20250311-07-1" author="system">
        <createSequence sequenceName="seq_i18n_message" startValue="1050" incrementBy="1"/>
    </changeSet>

    <changeSet id="20250311-07-2" author="system">
        <createTable tableName="i18n_message">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="short_code" type="varchar(500)">
                <constraints nullable="false" unique="true" uniqueConstraintName="ux_i18n_message_short_code"/>
            </column>
            <column name="localized_name" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="sort_order" type="bigint"/>
            <column name="created_date" type="${datetimeType}" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="last_modified_date" type="${datetimeType}" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="20250311-07-3" author="system" runOnChange="true">
        <sqlFile path="config/liquibase/sql/seed/seed_i18n_message.sql" relativeToChangelogFile="false"/>
    </changeSet>

</databaseChangeLog>
